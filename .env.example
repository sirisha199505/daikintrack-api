# Database Configuration
DB_URL=postgresql://user:password@host:5432/database?sslmode=require

# JWT Secret - Generate a secure random string (e.g., openssl rand -hex 64)
JWT_SECRET=your-secure-random-secret-here-change-this

# AWS Configuration (for S3)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1

# Email/SMTP Configuration
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_DOMAIN=example.com
EMAIL_USER=noreply@example.com
EMAIL_PASSWORD=your-email-password

# Application Settings
RACK_ENV=development
POOL_SIZE=5

# Stripe (if using payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-key

# New Relic (for monitoring)
NEW_RELIC_LICENSE_KEY=your-newrelic-key
NEW_RELIC_APP_NAME=your-app-name
